{
  "name": "@aidraw/agentdraw",
  "version": "0.1.7",
  "type": "module",
  "description": "Local-first editable whiteboard workspace for coding agents.",
  "license": "MIT",
  "bin": {
    "agentdraw": "dist/index.js"
  },
  "files": [
    "dist",
    "web-dist",
    "designs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --external:@resvg/resvg-js --outfile=dist/index.js",
    "bundle:web": "rm -rf web-dist && cp -R ../../apps/web/dist web-dist",
    "bundle:designs": "rm -rf designs && cp -R ../../packages/styles/designs designs",
    "prepack": "pnpm build && pnpm bundle:web && pnpm bundle:designs",
    "start": "tsx src/index.ts",
    "typecheck": "pnpm --filter @agentdraw/server build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@agentdraw/scene": "workspace:*",
    "@agentdraw/server": "workspace:*",
    "@agentdraw/styles": "workspace:*",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/chenhg5/agentdraw.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "agent",
    "whiteboard",
    "excalidraw",
    "diagram",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  }
}
